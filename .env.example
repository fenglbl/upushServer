# GeTui credentials are used for Android push only.
GETUI_APPKEY=your_getui_appkey
GETUI_MASTERSECRET=your_getui_mastersecret
GETUI_SERVER_URL=https://restapi.getui.com/v2/your_appid/
DB_HOST=your_db_host
DB_PORT=27017
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=upush
DB_AUTH_SOURCE=admin
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@your-domain.com
EMAIL_CODE_EXPIRE_MINUTES=5
EMAIL_CODE_SEND_COOLDOWN_SECONDS=60
EMAIL_CODE_SEND_WINDOW_MINUTES=10
EMAIL_CODE_SEND_MAX_PER_WINDOW=5
PORT=3000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080,http://localhost:8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_JWT_SECRET=change_this_to_a_long_random_secret
PUBLIC_DOWNLOAD_BASE_URL=https://your-domain.example.com
